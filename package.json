{
  "name": "verificador-matematico-cpf",
  "version": "1.0.0",
  "description": "Verificador Matemático de CPF - Validação estrutural de dígitos verificadores",
  "main": "main.js",
  "author": "GHZ Plugin",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.ghzplugin.verificadorcpf",
    "productName": "Verificador Matemático de CPF",
    "win": {
      "target": "nsis",
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Verificador Matemático de CPF"
    },
    "files": [
      "main.js",
      "index.html",
      "css/**/*",
      "js/**/*",
      "pages/**/*",
      "logo.png",
      "logo.ico"
    ]
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
